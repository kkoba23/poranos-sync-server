{
  "name": "poranos-desktop",
  "version": "1.0.5",
  "description": "Poranos Desktop App",
  "main": "main.js",
  "author": "Poranos",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.poranos.desktop",
    "productName": "Poranos Desktop",
    "directories": {
      "output": "../dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "poranos.ico",
      "poranos.png"
    ],
    "extraResources": [
      {
        "from": "../dist-pyinstaller/backend",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../dist-pyinstaller/sync-server",
        "to": "sync-server",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "poranos.ico",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "poranos.ico",
      "include": "installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "icon": "poranos.png",
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "artifactName": "PoranosDesktop-${version}-arm64.dmg"
    }
  }
}
